{
  "version": 2,
  "name": "hussein-portfolio",
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "admin/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "css/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "js/*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/projects.html",
      "dest": "/projects.html"
    },
    {
      "src": "/admin/login.html",
      "dest": "/admin/login.html"
    },
    {
      "src": "/admin/dashboard.html",
      "dest": "/admin/dashboard.html"
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    }
  ]
}